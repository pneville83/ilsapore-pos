# Variables de Entorno para la configuración del Bot de WhatsApp de Il Sapore POS

# --- 1. Configuración de Supabase ---
# Credenciales para conectar el bot a Supabase y gestionar el estado de las transferencias.
# SUPABASE_URL: URL de tu proyecto Supabase (ej. https://your-project-ref.supabase.co)
# SUPABASE_ANON_KEY: Tu clave pública (anon) de Supabase. Asegúrate de que tiene
#                    los permisos RLS adecuados para la tabla 'pending_transfers'.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- 2. Configuración de la API del Backend de Il Sapore POS ---
# Credenciales para que el bot se autentique y cree pedidos en tu backend.
# POS_API_BASE_URL: URL base de tu backend desplegado (o local si es para desarrollo).
# POS_LOGIN_ENDPOINT: Endpoint específico para el login en tu API.
# POS_USERNAME: Nombre de usuario de un administrador o usuario con permisos para crear pedidos.
# POS_PASSWORD: Contraseña de ese usuario. ¡Mantenla SEGURA!
POS_API_BASE_URL=
POS_LOGIN_ENDPOINT=/login
POS_USERNAME=
POS_PASSWORD=

# --- 3. Número de WhatsApp para Gestión Interna ---
# Número de WhatsApp (formato con @c.us, ej: 5939XXXXXXXX@@lid)al que el bot enviará
# notificaciones de transferencias pendientes para verificación manual.
NUMERO_GESTION_CUENTAS=

# --- 4. Configuración de PayPhone ---
# Credenciales para integrar el pago con tarjeta a través de PayPhone.
# PAYPHONE_API_KEY: El token de autenticación largo que te proporciona PayPhone.
# PAYPHONE_STORE_ID: El identificador de tu tienda/comercio en PayPhone (formato UUID).
# PAYPHONE_CLIENT_ID: El ID de cliente que PayPhone te proporciona para tu aplicación.
# PAYPHONE_GENERATE_LINK_URL: Endpoint para generar el enlace de pago.
# PAYPHONE_CHECK_STATUS_URL: Endpoint para verificar el estado de una transacción (usado en el backend).
# PAYPHONE_RESPONSE_URL: URL a la que PayPhone redirige al cliente tras un pago exitoso (configurada en el backend).
# PAYPHONE_CANCELLATION_URL: URL a la que PayPhone redirige tras una cancelación (configurada en el backend).
PAYPHONE_API_KEY=
PAYPHONE_STORE_ID=
PAYPHONE_CLIENT_ID=
PAYPHONE_GENERATE_LINK_URL=https://pay.payphonetodoesposible.com/api/Links
PAYPHONE_CHECK_STATUS_URL=https://pay.payphonetodoesposible.com/api/transaction
PAYPHONE_RESPONSE_URL=
PAYPHONE_CANCELLATION_URL=