# Variables de Entorno para la configuración del Backend de Il Sapore POS

# --- 1. Configuración de la Base de Datos (PostgreSQL) ---
# Credenciales de conexión a tu base de datos PostgreSQL.
# Para desarrollo local, podrían ser tus credenciales de PostgreSQL local.
# Para despliegue en Render, Render inyecta sus propias variables si usas base de datos gestionada,
# o usarías estas si te conectas a una DB externa.
DB_USER=
DB_HOST=
DB_DATABASE=
DB_PASSWORD= # <<< ¡REEMPLAZA CON TU CONTRASEÑA REAL!
DB_PORT=5432 # Puerto estándar de PostgreSQL, ajusta si es diferente (ej. 6543 para Supabase Pooler)

# --- 2. Configuración de la Impresora de Tickets ---
# Interfaz de la impresora térmica compartida en la red local.
# Ej: \\NOMBRE_COMPUTADORA\NOMBRE_IMPRESORA_COMPARTIDA
PRINTER_INTERFACE=

# --- 3. Configuración del Servidor Backend ---
# Puerto en el que escuchará el servidor Express.
PORT=4000

# --- 4. Secreto JWT para Autenticación ---
# Clave secreta para firmar y verificar JSON Web Tokens (JWT).
# ¡Genera una cadena aleatoria fuerte y mantenla segura!
JWT_SECRET=

# --- 5. Configuración de Supabase (para webhooks y operaciones con pending_transfers) ---
# Estas son las credenciales de tu proyecto Supabase.
SUPABASE_URL= # URL de tu proyecto Supabase (ej. https://your-project-ref.supabase.co)
SUPABASE_ANON_KEY= # Tu clave pública (anon) de Supabase, con permisos de RLS para 'pending_transfers'

# --- 6. Configuración de PayPhone para Redirecciones ---
# URLs a las que PayPhone redirigirá al cliente después de un pago/cancelación.
# Deben ser públicas y accesibles desde PayPhone (normalmente tu URL de backend desplegada).
PAYPHONE_RESPONSE_URL= # Ej: https://your-backend.onrender.com/payphone/success
PAYPHONE_CANCELLATION_URL= # Ej: https://your-backend.onrender.com/payphone/cancel

# --- 7. (Opcional) Secreto del Webhook de PayPhone ---
# Si PayPhone proporciona un secreto para firmar sus webhooks (para mayor seguridad).
# Descomentar y rellenar si es aplicable y quieres verificar la firma.
# PAYPHONE_WEBHOOK_SECRET=